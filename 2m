<script>

/* ---------- LOGIN / LOGOUT ---------- */

function login(){
    const email = document.getElementById("loginEmail").value.trim();
    const password = document.getElementById("loginPassword").value;
    const errorBox = document.getElementById("loginError");

    if(!email || !password){
        errorBox.textContent = "Please enter both email and password.";
        return;
    }

    errorBox.textContent = "";
    document.getElementById("loginPage").style.display = "none";
    document.getElementById("dashboard").style.display = "block";

    const role = document.getElementById("role").value;
    document.getElementById("welcome").innerHTML = role === "admin" ? "Administrator" : "Employee";

    renderTickets();
}

function logout(){
    document.getElementById("dashboard").style.display = "none";
    document.getElementById("loginPage").style.display = "flex";
    document.getElementById("loginEmail").value = "";
    document.getElementById("loginPassword").value = "";
}

/* ---------- NAVIGATION ---------- */

function showView(viewId, btn){
    document.querySelectorAll(".view").forEach(v => v.classList.remove("active"));
    document.getElementById(viewId).classList.add("active");

    document.querySelectorAll(".nav-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
}

/* ---------- TICKETS (données en mémoire, pas de backend) ---------- */

let tickets = [
    { id: 1001, employee: "Ahmed", department: "Broadcast", status: "Open", priority: "Critical" },
    { id: 1002, employee: "Sarah", department: "IT", status: "In Progress", priority: "Medium" },
    { id: 1003, employee: "Karim", department: "Production", status: "Closed", priority: "Low" }
];
let nextTicketId = 1004;

function submitTicket(){
    const subject = document.getElementById("tSubject").value.trim();
    const employee = document.getElementById("tEmployee").value.trim() || "Anonymous";
    const department = document.getElementById("tDept").value;
    const priority = document.getElementById("tPriority").value;

    if(!subject){
        alert("Please enter a subject for the ticket.");
        return;
    }

    tickets.unshift({ id: nextTicketId++, employee, department, status: "Open", priority });

    document.getElementById("tSubject").value = "";
    document.getElementById("tEmployee").value = "";
    document.getElementById("tDesc").value = "";
    document.getElementById("tComments").value = "";

    const msg = document.getElementById("formMsg");
    msg.style.display = "block";
    setTimeout(() => msg.style.display = "none", 2500);

    renderTickets();
}

function updateStatus(id, newStatus){
    const ticket = tickets.find(t => t.id === id);
    if(ticket){
        ticket.status = newStatus;
        renderTickets();
    }
}

function statusClass(status){
    if(status === "Open") return "status-open";
    if(status === "In Progress") return "status-progress";
    return "status-closed";
}

function renderTickets(){
    // Tableau complet dans l'onglet Tickets
    const body = document.getElementById("ticketTableBody");
    body.innerHTML = tickets.map(t => `
        <tr>
            <td>#${t.id}</td>
            <td>${t.employee}</td>
            <td>${t.department}</td>
            <td>
                <select class="status-select" onchange="updateStatus(${t.id}, this.value)">
                    <option ${t.status === "Open" ? "selected" : ""}>Open</option>
                    <option ${t.status === "In Progress" ? "selected" : ""}>In Progress</option>
                    <option ${t.status === "Closed" ? "selected" : ""}>Closed</option>
                </select>
            </td>
            <td class="${statusClass(t.status)}">${t.priority}</td>
        </tr>
    `).join("");

    // Aperçu (3 derniers) sur la page Dashboard
    const preview = document.getElementById("homeTicketPreview");
    const recent = tickets.slice(0, 3);
    preview.innerHTML = `
        <table>
            <tr><th>ID</th><th>Employee</th><th>Department</th><th>Status</th></tr>
            ${recent.map(t => `
                <tr>
                    <td>#${t.id}</td>
                    <td>${t.employee}</td>
                    <td>${t.department}</td>
                    <td class="${statusClass(t.status)}">${t.status}</td>
                </tr>
            `).join("")}
        </table>
    `;

    updateStats();
}

function updateStats(){
    let open = 0, progress = 0, closed = 0;
    tickets.forEach(t => {
        if(t.status === "Open") open++;
        else if(t.status === "In Progress") progress++;
        else closed++;
    });
    document.getElementById("statOpen").textContent = open;
    document.getElementById("statProgress").textContent = progress;
    document.getElementById("statClosed").textContent = closed;
}

/* ---------- USERS (données en mémoire, pas de backend) ---------- */

let users = [
    { name: "Ahmed Bennani", email: "ahmed.bennani@2mtv.ma", role: "admin" },
    { name: "Sarah El Amrani", email: "sarah.elamrani@2mtv.ma", role: "employee" },
    { name: "Karim Tazi", email: "karim.tazi@2mtv.ma", role: "employee" }
];

function renderUsers(){
    const list = document.getElementById("usersList");
    list.innerHTML = users.map(u => `
        <div class="user-card">
            <div class="user-info">
                <strong>${u.name}</strong><br>
                <small>${u.email}</small>
            </div>
            <span class="badge ${u.role}">${u.role === "admin" ? "Administrator" : "Employee"}</span>
        </div>
    `).join("");
}

function addUser(){
    const name = document.getElementById("newName").value.trim();
    const email = document.getElementById("newEmail").value.trim();
    const role = document.getElementById("newRole").value;
    const errorBox = document.getElementById("userFormError");
    const msgBox = document.getElementById("userFormMsg");

    errorBox.textContent = "";

    if(!name || !email){
        errorBox.textContent = "Name and email are required.";
        return;
    }

    users.push({ name, email, role });

    document.getElementById("newName").value = "";
    document.getElementById("newEmail").value = "";

    msgBox.style.display = "block";
    setTimeout(() => msgBox.style.display = "none", 2500);

    renderUsers();
}

/* ---------- INITIALISATION ---------- */

renderUsers();
renderTickets();

</script>



