function renderDropdownGrid() {
  const search = (document.getElementById('dropdown-search').value || '').toLowerCase();
  const list = DROPDOWN_CATEGORIES.filter(c => c.label.toLowerCase().includes(search));
  const container = document.getElementById('dropdown-grid-container');
  if (list.length === 0) {
    container.innerHTML = `<div class="card" style="grid-column:1/-1;"><div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <h3>No dropdown categories found</h3><p>Try a different search term</p></div></div>`;
    return;
  }
  container.innerHTML = list.map(c => `
    <div class="dropdown-cat-card" onclick="navigateTo('placeholder','${c.label.replace(/'/g,"\\'")}','dropdowns')">
      <svg class="cat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${c.icon}</svg>
      <span class="cat-label">${c.label}</span>
      <svg class="cat-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </div>`).join('');
}

/* ===================== MODAL (Problems / Changes / Planning / Users / Profiles / LDAP) ===================== */
let currentModalType = null;

function openModal(type) {
  currentModalType = type;
  const title = document.getElementById('modal-title');
  const body = document.getElementById('modal-body');

  if (type === 'problem') {
    title.textContent = 'New Problem';
    body.innerHTML = `
      <div class="form-group"><label>Title</label><input type="text" id="m-title"></div>
      <div class="form-group"><label>Impact</label>
        <select id="m-impact"><option>Low</option><option selected>Medium</option><option>High</option></select></div>
      <div class="form-group"><label>Related Ticket ID (optional)</label><input type="text" id="m-related"></div>`;
  } else if (type === 'change') {
    title.textContent = 'New Change';
    body.innerHTML = `
      <div class="form-group"><label>Title</label><input type="text" id="m-title"></div>
      <div class="form-group"><label>Type</label>
        <select id="m-type"><option>Standard</option><option>Normal</option><option>Emergency</option></select></div>
      <div class="form-group"><label>Department</label>
        <select id="m-department"><option>Broadcast</option><option>IT</option><option>Production</option><option>Journalism</option><option>Maintenance</option><option>HR</option></select></div>
      <div class="form-group"><label>Scheduled Date</label><input type="date" id="m-date"></div>`;
  } else if (type === 'planning') {
    title.textContent = 'New Planning Item';
    body.innerHTML = `
      <div class="form-group"><label>Title</label><input type="text" id="m-title"></div>
      <div class="form-group"><label>Date</label><input type="date" id="m-date"></div>
      <div class="form-group"><label>Type</label>
        <select id="m-type"><option>Maintenance</option><option>Meeting</option><option>Deployment</option><option>Training</option></select></div>
      <div class="form-group"><label>Department</label>
        <select id="m-department"><option>Broadcast</option><option>IT</option><option>Production</option><option>Journalism</option><option>Maintenance</option><option>HR</option></select></div>
      <div class="form-group"><label>Notes (optional)</label><input type="text" id="m-notes"></div>`;
  } else if (type === 'user') {
    const editing = editingUserId ? DB.users.find(u => u.id === editingUserId) : null;
    title.textContent = editing ? 'Edit User' : 'Add User';
    const profileOptions = DB.profiles.map(p => `<option value="${p.name}">${p.name}</option>`).join('');
    body.innerHTML = `
      <div class="form-group"><label>Login</label><input type="text" id="m-login" value="${editing ? editing.login : ''}" placeholder="j.dupont"></div>
      <div class="form-group"><label>Name</label><input type="text" id="m-name" value="${editing ? editing.name : ''}" placeholder="Jean Dupont"></div>
      <div class="form-group"><label>Email</label><input type="text" id="m-email" value="${editing ? editing.email : ''}" placeholder="j.dupont@2mtv.ma"></div>
      <div class="form-group"><label>Category / Profile</label><select id="m-category"><option value="">—</option>${profileOptions}</select></div>
      <div class="form-group checkbox-row"><input type="checkbox" id="m-active" ${!editing || editing.active ? 'checked' : ''}><label style="margin:0;">Active</label></div>`;
    if (editing) setTimeout(() => { document.getElementById('m-category').value = editing.category || ''; }, 0);
  } else if (type === 'profile') {
    const editing = editingProfileId ? DB.profiles.find(p => p.id === editingProfileId) : null;
    title.textContent = editing ? 'Edit Profile' : 'Add Profile';
    body.innerHTML = `
      <div class="form-group"><label>Profile Name</label><input type="text" id="m-name" value="${editing ? editing.name : ''}" placeholder="Ex: Technician"></div>
      <div class="form-group"><label>Description</label><textarea id="m-description" placeholder="What this profile can do...">${editing ? editing.description : ''}</textarea></div>
      <div class="form-row">
        <div class="form-group"><label>Permissions count</label><input type="number" id="m-permissions" min="0" value="${editing ? editing.permissions : 5}"></div>
        <div class="form-group"><label>Users assigned</label><input type="number" id="m-users" min="0" value="${editing ? editing.usersAssigned : 0}"></div>
      </div>`;
  } else if (type === 'ldap') {
    const editing = editingLdapId ? DB.ldapMappings.find(m => m.id === editingLdapId) : null;
    title.textContent = editing ? 'Edit LDAP Mapping' : 'Add LDAP Mapping';
    const profileOptions = DB.profiles.map(p => `<option value="${p.name}">${p.name}</option>`).join('');
    body.innerHTML = `
      <div class="form-row">
        <div class="form-group"><label>Priority</label><input type="number" id="m-priority" min="0" value="${editing ? editing.priority : 10}"></div>
        <div class="form-group"><label>AD Group</label><input type="text" id="m-adgroup" value="${editing ? editing.adGroup : ''}" placeholder="Ex: Broadcast-Team"></div>
      </div>
      <div class="form-group"><label>Maps to Profile</label><select id="m-mapsto">${profileOptions}</select></div>
      <div class="form-group"><label>Description (optional)</label><input type="text" id="m-desc" value="${editing && editing.description !== '-' ? editing.description : ''}"></div>`;
    if (editing) setTimeout(() => { document.getElementById('m-mapsto').value = editing.mapsTo; }, 0);
  }
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  currentModalType = null;
  editingUserId = null;
  editingProfileId = null;
  editingLdapId = null;
}

function submitModal() {
  if (currentModalType === 'problem') {
    const title = document.getElementById('m-title').value.trim();
    if (!title) { alert('Le titre est requis'); return; }
    DB.problems.unshift({ id: nextId('problem', 'PRB'), title, impact: document.getElementById('m-impact').value, status: 'Open', relatedTicket: document.getElementById('m-related').value.trim(), createdAt: new Date().toISOString() });
    renderProblems();
  } else if (currentModalType === 'change') {
    const title = document.getElementById('m-title').value.trim();
    if (!title) { alert('Le titre est requis'); return; }
    DB.changes.unshift({ id: nextId('change', 'CHG'), title, type: document.getElementById('m-type').value, department: document.getElementById('m-department').value, scheduledDate: document.getElementById('m-date').value || '—', status: 'Planned', createdAt: new Date().toISOString() });
    renderChanges();
  } else if (currentModalType === 'planning') {
    const title = document.getElementById('m-title').value.trim();
    if (!title) { alert('Le titre est requis'); return; }
    DB.planning.unshift({ id: nextId('planning', 'PLN'), title, date: document.getElementById('m-date').value || '—', type: document.getElementById('m-type').value, department: document.getElementById('m-department').value, notes: document.getElementById('m-notes').value.trim() });
    renderPlanning();
  } else if (currentModalType === 'user') {
    const login = document.getElementById('m-login').value.trim();
    const name = document.getElementById('m-name').value.trim();
    if (!login || !name) { alert('Login et nom requis'); return; }
    const data = {
      login, name,
      email: document.getElementById('m-email').value.trim(),
      category: document.getElementById('m-category').value,
      active: document.getElementById('m-active').checked
    };
    if (editingUserId) {
      const u = DB.users.find(x => x.id === editingUserId);
      Object.assign(u, data);
    } else {
      DB.users.unshift({ id: nextId('user', 'USR'), entity: 'Root Entity', isAD: false, ...data });
    }
    renderUsers();
  } else if (currentModalType === 'profile') {
    const name = document.getElementById('m-name').value.trim();
    if (!name) { alert('Le nom du profil est requis'); return; }
    const data = {
      name,
      description: document.getElementById('m-description').value.trim(),
      permissions: parseInt(document.getElementById('m-permissions').value) || 0,
      usersAssigned: parseInt(document.getElementById('m-users').value) || 0
    };
    if (editingProfileId) {
      const p = DB.profiles.find(x => x.id === editingProfileId);
      Object.assign(p, data);
    } else {
      DB.profiles.unshift({ id: nextId('profile', 'PRF'), ...data });
    }
    renderProfiles();
  } else if (currentModalType === 'ldap') {
    const adGroup = document.getElementById('m-adgroup').value.trim();
    if (!adGroup) { alert("Le nom du groupe AD est requis"); return; }
    const data = {
      priority: parseInt(document.getElementById('m-priority').value) || 0,
      adGroup,
      mapsTo: document.getElementById('m-mapsto').value,
      description: document.getElementById('m-desc').value.trim() || '-'
    };
    if (editingLdapId) {
      const m = DB.ldapMappings.find(x => x.id === editingLdapId);
      Object.assign(m, data);
    } else {
      DB.ldapMappings.unshift({ id: nextId('ldap', 'LDP'), ...data });
    }
    renderLdap();
  }
  saveData(DB);
  closeModal();
}

