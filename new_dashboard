/* ===================== NOTIFICATIONS (queue + topbar dropdown) ===================== */
function addNotification(subject, to, body) {
  DB.notifications.unshift({
    id: nextId('notification', 'NTF'),
    to: to || 'all@2mtv.ma',
    subject: subject,
    type: 'System',
    status: 'Pending',
    body: body || '',
    createdAt: new Date().toISOString()
  });
  saveData(DB);
  renderNotifBell();
}

function renderNotifBell() {
  const pending = DB.notifications.filter(n => n.status === 'Pending');
  const badge = document.getElementById('notif-count-badge');
  badge.style.display = pending.length > 0 ? 'block' : 'none';
  const list = document.getElementById('notif-dropdown-list');
  if (DB.notifications.length === 0) {
    list.innerHTML = '<div class="notif-item">No notifications yet</div>';
    return;
  }
  list.innerHTML = DB.notifications.slice(0, 6).map(n => `
    <div class="notif-item"><span class="notif-dot"></span><strong style="color:var(--text-primary)">${n.subject}</strong><br>${n.body || ''}</div>
  `).join('');
}

function toggleNotifDropdown(e) {
  if (e) e.stopPropagation();
  document.getElementById('notif-dropdown').classList.toggle('open');
}
function closeNotifDropdown() {
  const d = document.getElementById('notif-dropdown');
  if (d) d.classList.remove('open');
}
document.addEventListener('click', function(e) {
  const bell = document.getElementById('notif-bell-btn');
  if (bell && !bell.contains(e.target)) closeNotifDropdown();
});

function renderNotificationsPage() {
  const search = (document.getElementById('notif-search').value || '').toLowerCase();
  const statusFilter = document.getElementById('notif-status-filter').value;
  let list = DB.notifications;
  if (search) list = list.filter(n => n.subject.toLowerCase().includes(search) || n.to.toLowerCase().includes(search));
  if (statusFilter) list = list.filter(n => n.status === statusFilter);

  const container = document.getElementById('notifications-container');
  if (list.length === 0) {
    container.innerHTML = `<div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <h3>Queue is empty</h3><p>Notifications will appear here as they are generated by the system</p></div>`;
    return;
  }
  const statusBadge = (s) => {
    if (s === 'Pending') return '<span class="badge status-in-progress">Pending</span>';
    if (s === 'Sent') return '<span class="badge status-resolved">Sent</span>';
    return '<span class="badge priority-critical">Failed</span>';
  };
  const rows = list.map(n => `
    <tr>
      <td>${n.id}</td>
      <td>${n.to}</td>
      <td>${n.subject}</td>
      <td>${n.type}</td>
      <td>${statusBadge(n.status)}</td>
      <td class="row-actions">
        <button class="btn btn-danger btn-sm" onclick="discardNotification('${n.id}')">Discard</button>
      </td>
    </tr>`).join('');
  container.innerHTML = `<table class="data-table">
    <thead><tr><th>ID</th><th>To</th><th>Subject</th><th>Type</th><th>Status</th><th>Actions</th></tr></thead>
    <tbody>${rows}</tbody>
  </table>`;
}

function discardNotification(id) {
  DB.notifications = DB.notifications.filter(n => n.id !== id);
  saveData(DB);
  renderNotificationsPage();
  renderNotifBell();
}
function discardAllNotifications() {
  if (DB.notifications.length === 0) return;
  if (!confirm('Discard the entire notification queue?')) return;
  DB.notifications = [];
  saveData(DB);
  renderNotificationsPage();
  renderNotifBell();
}

